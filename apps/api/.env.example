# Copy this file to .env and fill in real values for local development.
# Required (the app refuses to start without these):
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/project_green
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# Optional — sensible defaults apply if omitted
PORT=5000
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CORS_ORIGIN=http://localhost:3000
ENABLE_CRON=false

# Optional — without these, outbound email just logs to the console in dev/test
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@orchids.com

# Optional integrations — leave blank if unused
CLOUDINARY_URL=
CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=lkr
APP_PUBLIC_URL=http://localhost:3000
# Must be publicly reachable for real Stripe webhooks (localhost is fine for API tests only).
API_PUBLIC_URL=http://127.0.0.1:5000
EMAIL_ALLOWLIST=
